# MyPMOS — environment variables
#
# Copy this file to .env.local for local dev (it's gitignored — never commit it).
# Set the same vars in Vercel → Project Settings → Environment Variables for prod.
# Ask Alka for the shared dev values.
#
# The app degrades gracefully: with no keys it runs fully on-device
# (localStorage) and never breaks. Add Supabase + Gemini to unlock accounts,
# cross-device sync, Community, and the AI features.

# ============================================================================
# Database + auth — Supabase  (needed for accounts, sync, Community)
# ============================================================================

# Project URL, e.g. https://yourproject.supabase.co
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Public/browser key. Use the modern "publishable" key OR the legacy "anon" key
# (you only need ONE). The app prefers publishable and falls back to anon.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. Use the modern "secret" key OR the legacy "service_role"
# key (you only need ONE). NEVER expose this to the browser.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# AI — Google Gemini  (Learn articles + the "Ask" assistant)
# ============================================================================

# Google AI Studio → API keys: https://aistudio.google.com/apikey  (server only)
GEMINI_API_KEY=
# Optional — defaults to a fast Flash model if blank.
GEMINI_MODEL=gemini-flash-latest

# ============================================================================
# Web push reminders — OPTIONAL (app runs fine locally without these)
# ============================================================================

# Generate a keypair:  npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Shared secret that protects the reminders cron endpoint.
CRON_SECRET=

# ----------------------------------------------------------------------------
# Turning on accounts + sync:
#   1. Create a Supabase project; paste URL + a public key + a secret key above.
#   2. Run the migrations in supabase/migrations/ (Supabase SQL editor, in order).
#   3. (Optional, faster testing) Supabase → Auth → Providers → Email:
#      turn OFF "Confirm email" so sign-up logs you in immediately.
# ----------------------------------------------------------------------------
